generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  manager
  kasir
  dapur
}

enum Zone {
  indoor
  outdoor
  vip
}

enum OrderStatus {
  pending
  confirmed
  preparing
  delivered
  cancelled
}

enum PaymentMethod {
  qris
  cash
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum NotifType {
  new_order
  payment_confirmed
  order_delivered
  daily_report
}

enum NotifChannel {
  whatsapp
  sound
  push
}

enum NotifStatus {
  sent
  failed
  pending
}

enum OverrideStatus {
  open
  closed
}

enum VariationType {
  size
  temperature
  sweetness
  spiciness
  topping
}

enum Size {
  small
  medium
  large
}

enum Temperature {
  hot
  cold
  warm
}

enum Sweetness {
  less
  normal
  extra
}

enum Spiciness {
  none
  mild
  medium
  hot
  extra_hot
}

model User {
  id           Int      @id @default(autoincrement()) @map("user_id")
  name         String   @db.VarChar(100)
  email        String   @unique @db.VarChar(100)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         Role
  phone        String?  @db.VarChar(20)
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  orders           Order[]
  holidays         Holiday[]
  operationalHours OperationalHour[]

  @@map("users")
}

model Table {
  id          Int      @id @default(autoincrement()) @map("table_id")
  tableNumber Int      @unique @map("table_number")
  floor       Int      @default(1)
  zone        Zone
  qrCodeUrl   String?  @map("qr_code_url") @db.VarChar(255)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  orders Order[]

  @@map("tables")
}

model Category {
  id        Int      @id @default(autoincrement()) @map("category_id")
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(100)
  icon      String?  @db.VarChar(100)
  sortOrder Int      @default(0) @map("sort_order")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  menus Menu[]

  @@map("categories")
}

model Menu {
  id          Int      @id @default(autoincrement()) @map("menu_id")
  categoryId  Int      @map("category_id")
  name        String   @db.VarChar(150)
  description String?  @db.Text
  basePrice   Decimal  @map("base_price") @db.Decimal(10, 2)
  imageUrl    String?  @map("image_url") @db.VarChar(255)
  isAvailable Boolean  @default(true) @map("is_available")
  isSeasonal  Boolean  @default(false) @map("is_seasonal")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  category   Category        @relation(fields: [categoryId], references: [id])
  variations MenuVariation[]
  orderItems OrderItem[]

  @@map("menus")
}

model MenuVariation {
  id            Int           @id @default(autoincrement()) @map("variation_id")
  menuId        Int           @map("menu_id")
  variationType VariationType @map("variation_type")
  label         String        @db.VarChar(100)
  priceModifier Decimal       @default(0) @map("price_modifier") @db.Decimal(10, 2)
  isDefault     Boolean       @default(false) @map("is_default")
  isActive      Boolean       @default(true) @map("is_active")

  menu Menu @relation(fields: [menuId], references: [id])

  @@map("menu_variations")
}

model Order {
  id            Int           @id @default(autoincrement()) @map("order_id")
  tableId       Int           @map("table_id")
  confirmedBy   Int?          @map("confirmed_by")
  orderNumber   String        @unique @map("order_number") @db.VarChar(20)
  status        OrderStatus   @default(pending)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(10, 2)
  paymentMethod PaymentMethod @map("payment_method")
  sessionRound  Int           @default(1) @map("session_round")
  orderedAt     DateTime      @default(now()) @map("ordered_at")
  deliveredAt   DateTime?     @map("delivered_at")

  table           Table          @relation(fields: [tableId], references: [id])
  confirmedByUser User?          @relation(fields: [confirmedBy], references: [id])
  orderItems      OrderItem[]
  payment         Payment?
  notifications   Notification[]

  @@map("orders")
}

model OrderItem {
  id          Int         @id @default(autoincrement()) @map("item_id")
  orderId     Int         @map("order_id")
  menuId      Int         @map("menu_id")
  quantity    Int
  unitPrice   Decimal     @map("unit_price") @db.Decimal(10, 2)
  subtotal    Decimal     @db.Decimal(10, 2)
  size        Size?
  temperature Temperature?
  sweetness   Sweetness?
  spiciness   Spiciness?
  toppings    Json?
  specialNote String?     @map("special_note") @db.Text

  order Order @relation(fields: [orderId], references: [id])
  menu  Menu  @relation(fields: [menuId], references: [id])

  @@map("order_items")
}

model Payment {
  id            Int           @id @default(autoincrement()) @map("payment_id")
  orderId       Int           @unique @map("order_id")
  method        PaymentMethod
  amount        Decimal       @db.Decimal(10, 2)
  qrisRefNumber String?       @map("qris_ref_number") @db.VarChar(100)
  status        PaymentStatus @default(pending)
  customerPhone String?       @map("customer_phone") @db.VarChar(20)
  receiptSent   Boolean       @default(false) @map("receipt_sent")
  paidAt        DateTime?     @map("paid_at")

  order         Order          @relation(fields: [orderId], references: [id])
  notifications Notification[]

  @@map("payments")
}

model Notification {
  id             Int          @id @default(autoincrement()) @map("notif_id")
  orderId        Int?         @map("order_id")
  paymentId      Int?         @map("payment_id")
  type           NotifType
  channel        NotifChannel
  recipientPhone String?      @map("recipient_phone") @db.VarChar(20)
  message        String?      @db.Text
  status         NotifStatus  @default(pending)
  sentAt         DateTime?    @map("sent_at")

  order   Order?   @relation(fields: [orderId], references: [id])
  payment Payment? @relation(fields: [paymentId], references: [id])

  @@map("notifications")
}

model DailyReport {
  id             Int       @id @default(autoincrement()) @map("report_id")
  reportDate     DateTime  @unique @map("report_date") @db.Date
  totalRevenue   Decimal   @map("total_revenue") @db.Decimal(10, 2)
  totalOrders    Int       @map("total_orders")
  totalCustomers Int       @map("total_customers")
  qrisRevenue    Decimal   @map("qris_revenue") @db.Decimal(10, 2)
  cashRevenue    Decimal   @map("cash_revenue") @db.Decimal(10, 2)
  peakHour       DateTime? @map("peak_hour") @db.Time
  topMenuId      Int?      @map("top_menu_id")
  generatedAt    DateTime  @default(now()) @map("generated_at")

  @@map("daily_reports")
}

model Holiday {
  id          Int      @id @default(autoincrement()) @map("holiday_id")
  createdBy   Int      @map("created_by")
  holidayDate DateTime @map("holiday_date") @db.Date
  label       String   @db.VarChar(100)
  isClosed    Boolean  @default(true) @map("is_closed")
  createdAt   DateTime @default(now()) @map("created_at")

  createdByUser User @relation(fields: [createdBy], references: [id])

  @@map("holidays")
}

model OperationalHour {
  id               Int             @id @default(autoincrement()) @map("op_id")
  updatedBy        Int             @map("updated_by")
  openTime         DateTime        @map("open_time") @db.Time
  closeTime        DateTime        @map("close_time") @db.Time
  isManualOverride Boolean         @default(false) @map("is_manual_override")
  overrideStatus   OverrideStatus? @map("override_status")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  updatedByUser User @relation(fields: [updatedBy], references: [id])

  @@map("operational_hours")
}
